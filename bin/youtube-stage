#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/youtube-stage URL [--temp-dir PATH] [--env-file PATH]

Description:
  Stages one YouTube URL as a local Jellyfin movie folder under EMPIRE_TEMP_DIR.
  The output directory is named for the video id and contains movie.mp4 plus
  Jellyfin sidecars such as empire.json, movie.nfo, and fanart.jpg when a
  thumbnail is available.

Examples:
  bin/youtube-stage "https://www.youtube.com/watch?v=y7zqvSpt1gw"
  bin/youtube-stage "https://www.youtube.com/watch?v=y7zqvSpt1gw" --temp-dir /tmp/empire

Options:
  --temp-dir PATH   Stage into this directory instead of EMPIRE_TEMP_DIR.
  --env-file PATH   Load an environment file before running.
                    Defaults to deploy/env/local.env.
  -h, --help        Show this help message.
EOF
}

ENV_FILE="deploy/env/local.env"
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env-file)
      ENV_FILE="${2:-}"
      if [[ -z "${ENV_FILE}" ]]; then
        echo "ERROR: --env-file requires a path." >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "ERROR: env file not found: ${ENV_FILE}" >&2
  exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${REPO_ROOT}/packages/empire-youtube/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "ERROR: python3 was not found." >&2
  exit 1
fi

set -a
source "${ENV_FILE}"
set +a

export PYTHONPATH="${REPO_ROOT}/packages/empire-youtube/src:${REPO_ROOT}/packages/empire-core/src${PYTHONPATH:+:${PYTHONPATH}}"

if ! "${PYTHON_BIN}" -c 'import empire_core, requests' >/dev/null 2>&1; then
  echo "ERROR: empire-youtube dependencies are not installed for ${PYTHON_BIN}." >&2
  echo "       Run: cd packages/empire-youtube && poetry install" >&2
  exit 1
fi

if ! command -v yt-dlp >/dev/null 2>&1; then
  echo "ERROR: yt-dlp was not found on PATH." >&2
  exit 1
fi

"${PYTHON_BIN}" "${REPO_ROOT}/packages/empire-youtube/src/empire_youtube/scripts/stage.py" "${ARGS[@]}"
