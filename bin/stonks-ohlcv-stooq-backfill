#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/stonks-ohlcv-stooq-backfill \
    --input-path PATH \
    --effective-date YYYY-MM-DD \
    [--start-date YYYY-MM-DD] \
    [--end-date YYYY-MM-DD] \
    [--market MARKET ...] \
    [--ticker TICKER.US ...] \
    [--chunk-size ROWS] \
    [--env-file PATH]

Description:
  Loads the Empire environment and runs the package-owned, one-shot Stooq
  historical OHLCV backfill. This command does not download from Stooq and
  does not mutate canonical identity tables. Progress is JSON on stderr;
  successful stdout is one compact secret-safe JSON result.

Options:
  --input-path PATH       Required existing local d_us_txt.zip archive.
  --effective-date DATE   Required archive acquisition date (YYYY-MM-DD).
  --start-date DATE       Optional inclusive earliest trading date.
  --end-date DATE         Optional inclusive latest trading date.
  --market MARKET         Include nasdaq, nyse, or nysemkt; repeat as needed.
                          Defaults to all three markets.
  --ticker TICKER.US      Include an exact uppercase ticker; repeat as needed.
                          Defaults to every ticker in the selected markets.
  --chunk-size ROWS       Bars per database transaction (default 50000;
                          maximum 100000).
  --env-file PATH         Load an environment file before running.
                          Defaults to deploy/env/local.env.
  -h, --help              Show this help message.
EOF
}

ENV_FILE="deploy/env/local.env"
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env-file)
      ENV_FILE="${2:-}"
      if [[ -z "${ENV_FILE}" ]]; then
        echo "ERROR: --env-file requires a path." >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      ARGS+=("$@")
      break
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=bin/env-load
source "${REPO_ROOT}/bin/env-load" "${ENV_FILE}" >/dev/null

PYTHON_BIN="${REPO_ROOT}/packages/empire-stonks-ohlcv/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "ERROR: python3 was not found." >&2
  exit 1
fi

export PYTHONPATH="${REPO_ROOT}/packages/empire-stonks-ohlcv/src:${REPO_ROOT}/packages/empire-core/src${PYTHONPATH:+:${PYTHONPATH}}"

if ! "${PYTHON_BIN}" -c 'import empire_core, empire_stonks_ohlcv' >/dev/null 2>&1; then
  echo "ERROR: empire-stonks-ohlcv dependencies are not installed for ${PYTHON_BIN}." >&2
  echo "       Run: cd packages/empire-stonks-ohlcv && poetry install" >&2
  exit 1
fi

exec "${PYTHON_BIN}" -m empire_stonks_ohlcv.scripts.stooq_backfill "${ARGS[@]}"
