#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/run-nuke RUN_ID [--env-file PATH] [--dry-run] [--yes]

Description:
  Completely removes one run and its stored objects.

  This is intended for local/dev cleanup. It:
    1. Deletes active physical files for the run.
    2. Marks active object metadata deleted.
    3. Purges all deleted object metadata for the run immediately.
    4. Deletes the core.core_run row.

  Normal cleanup should prefer:
    bin/run-objects-cleanup RUN_ID
    bin/run-objects-purge RUN_ID

Examples:
  bin/run-nuke 79f89602-0e85-4765-84b7-82c6284b4fb6 --dry-run
  bin/run-nuke 79f89602-0e85-4765-84b7-82c6284b4fb6 --yes

Options:
  --env-file PATH  Load an environment file before running.
                   Defaults to deploy/env/local.env.
  --dry-run        Print what would be removed without changing files or DB.
  --yes            Required to perform the destructive removal.
  -h, --help       Show this help message.
EOF
}

ENV_FILE="deploy/env/local.env"
DRY_RUN="false"
YES="false"
RUN_ID=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env-file)
      ENV_FILE="${2:-}"
      if [[ -z "${ENV_FILE}" ]]; then
        echo "ERROR: --env-file requires a path." >&2
        exit 1
      fi
      shift 2
      ;;
    --dry-run)
      DRY_RUN="true"
      shift
      ;;
    --yes)
      YES="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "ERROR: unknown argument: $1" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "${RUN_ID}" ]]; then
        echo "ERROR: only one RUN_ID may be provided." >&2
        exit 1
      fi
      RUN_ID="$1"
      shift
      ;;
  esac
done

if [[ -z "${RUN_ID}" ]]; then
  echo "ERROR: RUN_ID is required." >&2
  echo >&2
  usage >&2
  exit 1
fi

if [[ "${DRY_RUN}" != "true" && "${YES}" != "true" ]]; then
  echo "ERROR: run-nuke is destructive. Re-run with --yes or inspect with --dry-run." >&2
  exit 1
fi

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "ERROR: env file not found: ${ENV_FILE}" >&2
  exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${REPO_ROOT}/packages/empire-core/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "ERROR: python3 was not found." >&2
  exit 1
fi

set -a
source "${ENV_FILE}"
set +a

export PYTHONPATH="${REPO_ROOT}/packages/empire-core/src${PYTHONPATH:+:${PYTHONPATH}}"
export EMPIRE_NUKE_RUN_RUN_ID="${RUN_ID}"
export EMPIRE_NUKE_RUN_DRY_RUN="${DRY_RUN}"

"${PYTHON_BIN}" "${REPO_ROOT}/packages/empire-core/src/empire_core/scripts/nuke_run.py"
