#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/youtube-download (--plan-object-id ID | --plan-run-id RUN_ID)
                       [--video-id VIDEO_ID | --list]
                       [--cleanup-on-failure]
                       [--env-file PATH]

Description:
  Downloads one video from a YouTube library plan into the Jellyfin object
  store as movie.mp4. Use --list to inspect available video ids.

Examples:
  bin/youtube-download --plan-object-id 00000000-0000-0000-0000-000000000000 --list
  bin/youtube-download --plan-run-id 00000000-0000-0000-0000-000000000000 --video-id abc123
  bin/youtube-download --plan-object-id 00000000-0000-0000-0000-000000000000 --video-id abc123 --cleanup-on-failure

Options:
  --plan-object-id ID      Read youtube-library-plan.json from a stored object id.
  --plan-run-id ID         Read youtube-library-plan.json from a processor run id.
  --video-id ID            Download this YouTube video id.
  --list                   List video ids in the plan and exit.
  --cleanup-on-failure     Delete sidecars for the video if download fails.
  --env-file PATH          Load an environment file before running.
                           Defaults to deploy/env/local.env.
  --run-type TYPE          Empire run type. Defaults to cli.
  --runner NAME            Runner name recorded in run context.
  -h, --help               Show this help message.
EOF
}

ENV_FILE="deploy/env/local.env"
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env-file)
      ENV_FILE="${2:-}"
      if [[ -z "${ENV_FILE}" ]]; then
        echo "ERROR: --env-file requires a path." >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "ERROR: env file not found: ${ENV_FILE}" >&2
  exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${REPO_ROOT}/packages/empire-youtube/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "ERROR: python3 was not found." >&2
  exit 1
fi

set -a
source "${ENV_FILE}"
set +a

export PYTHONPATH="${REPO_ROOT}/packages/empire-youtube/src:${REPO_ROOT}/packages/empire-core/src${PYTHONPATH:+:${PYTHONPATH}}"

if ! "${PYTHON_BIN}" -c 'import empire_core' >/dev/null 2>&1; then
  echo "ERROR: empire-youtube dependencies are not installed for ${PYTHON_BIN}." >&2
  echo "       Run: cd packages/empire-youtube && poetry install" >&2
  exit 1
fi

if ! command -v yt-dlp >/dev/null 2>&1; then
  echo "ERROR: yt-dlp was not found on PATH." >&2
  exit 1
fi

"${PYTHON_BIN}" "${REPO_ROOT}/packages/empire-youtube/src/empire_youtube/scripts/download.py" "${ARGS[@]}"
