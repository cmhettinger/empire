#!/usr/bin/env bash

usage() {
  cat <<'EOF'
Usage:
  source bin/env-load [ENV_FILE]
  . bin/env-load [ENV_FILE]

Description:
  Loads an Empire environment file into the CURRENT shell (mac/local dev).

Environment file:
  ./deploy/env/local.env by default

Examples:
  source bin/env-load
  source bin/env-load deploy/env/local.example.env
  source bin/env-load /absolute/path/to/other.env

Options:
  -h, --help   Show this help message

IMPORTANT:
  This script MUST be sourced. Running it directly will NOT persist
  environment variables in your shell.
EOF
}

is_sourced() {
  if [[ -n "${ZSH_VERSION:-}" ]]; then
    [[ "${ZSH_EVAL_CONTEXT:-}" == *:file* ]]
    return
  fi

  if [[ -n "${BASH_VERSION:-}" ]]; then
    [[ "${BASH_SOURCE[0]}" != "$0" ]]
    return
  fi

  return 1
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  return 0 2>/dev/null || exit 0
fi

if ! is_sourced; then
  echo "ERROR: env-load must be sourced, not executed." >&2
  echo >&2
  usage >&2
  exit 1
fi

ENV_FILE="${1:-deploy/env/local.env}"

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "ERROR: env file not found: ${ENV_FILE}" >&2
  echo "       Run this from the Empire repo root, or pass an env file path." >&2
  return 1
fi

echo "==> Loading Empire environment from: ${ENV_FILE}"

set -a
source "${ENV_FILE}"
set +a

echo "==> Empire environment loaded."
