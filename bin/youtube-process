#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  bin/youtube-process (--input-file PATH | --input-object-id OBJECT_ID | --input-run-id RUN_ID)
                      [--env-file PATH]

Description:
  Processes YouTube scraper JSON and writes a Jellyfin library plan to the
  Empire object store.

Examples:
  bin/youtube-process --input-file /tmp/youtube-scraper.json
  bin/youtube-process --input-object-id 00000000-0000-0000-0000-000000000000
  bin/youtube-process --input-run-id 00000000-0000-0000-0000-000000000000

Options:
  --input-file PATH       Read scraper JSON from a local file.
  --input-object-id ID    Read scraper JSON from a specific stored object id.
  --input-run-id ID       Read youtube-scraper.json from a prior run.
  --env-file PATH         Load an environment file before running.
                          Defaults to deploy/env/local.env.
  --run-type TYPE         Empire run type. Defaults to cli.
  --runner NAME           Runner name recorded in run context.
  -h, --help              Show this help message.
EOF
}

ENV_FILE="deploy/env/local.env"
ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --env-file)
      ENV_FILE="${2:-}"
      if [[ -z "${ENV_FILE}" ]]; then
        echo "ERROR: --env-file requires a path." >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ ! -f "${ENV_FILE}" ]]; then
  echo "ERROR: env file not found: ${ENV_FILE}" >&2
  exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON_BIN="${REPO_ROOT}/packages/empire-youtube/.venv/bin/python"

if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi

if [[ -z "${PYTHON_BIN}" ]]; then
  echo "ERROR: python3 was not found." >&2
  exit 1
fi

set -a
source "${ENV_FILE}"
set +a

export PYTHONPATH="${REPO_ROOT}/packages/empire-youtube/src:${REPO_ROOT}/packages/empire-core/src${PYTHONPATH:+:${PYTHONPATH}}"

if ! "${PYTHON_BIN}" -c 'import empire_core' >/dev/null 2>&1; then
  echo "ERROR: empire-youtube dependencies are not installed for ${PYTHON_BIN}." >&2
  echo "       Run: cd packages/empire-youtube && poetry install" >&2
  exit 1
fi

"${PYTHON_BIN}" "${REPO_ROOT}/packages/empire-youtube/src/empire_youtube/scripts/process.py" "${ARGS[@]}"
