EMPIRE_DOCKER_NETWORK=empire-net

EMPIRE_POSTGRES_CONTAINER=empire-postgres
EMPIRE_POSTGRES_DATA_DIR=/Users/me/empire/empire-db/postgres
POSTGRES_VERSION=18.4
POSTGRES_DB=empire
POSTGRES_USER=empire
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5432

EMPIRE_DB_HOST=localhost
EMPIRE_DB_PORT=5432
EMPIRE_DB_NAME=empire
EMPIRE_DB_USER=empire
EMPIRE_DB_PASSWORD=change-me

EMPIRE_PGBOUNCER_CONTAINER=empire-pgbouncer
PGBOUNCER_VERSION=v1.25.1-p0
PGBOUNCER_HOST_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

EMPIRE_FLYWAY_CONTAINER=empire-flyway
FLYWAY_VERSION=12.6.1
FLYWAY_DEFAULT_SCHEMA=core
FLYWAY_SCHEMAS=core,stonks
FLYWAY_LOCATIONS=filesystem:/flyway/sql
FLYWAY_CONNECT_RETRIES=20
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_VALIDATE_MIGRATION_NAMING=true

EMPIRE_AIRFLOW_IMAGE=empire-airflow:3.2.1
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW_FERNET_KEY=change-me
AIRFLOW_API_AUTH_JWT_SECRET=change-me
AIRFLOW_API_SECRET_KEY=change-me
AIRFLOW_HOST_PORT=8080
AIRFLOW_WORKER_CONCURRENCY=4
AIRFLOW_DAG_REFRESH_INTERVAL=10
AIRFLOW_DAG_MIN_FILE_PROCESS_INTERVAL=10
EMPIRE_AIRFLOW_LOGS_DIR=./data/airflow/logs
EMPIRE_AIRFLOW_PLUGINS_DIR=./data/airflow/plugins
EMPIRE_OUTPUT_DIR=./data/output
EMPIRE_AIRFLOW_INIT_CONTAINER=empire-airflow-init
EMPIRE_AIRFLOW_API_CONTAINER=empire-airflow-api
EMPIRE_AIRFLOW_SCHEDULER_CONTAINER=empire-airflow-scheduler
EMPIRE_AIRFLOW_DAG_PROCESSOR_CONTAINER=empire-airflow-dag-processor
EMPIRE_AIRFLOW_TRIGGERER_CONTAINER=empire-airflow-triggerer
EMPIRE_AIRFLOW_WORKER_CONTAINER=empire-airflow-worker
EMPIRE_AIRFLOW_POOL_YOUTUBE_DOWNLOAD_SLOTS=1

EMPIRE_REDIS_CONTAINER=empire-redis
REDIS_VERSION=8.6.3

EMPIRE_JELLYFIN_CONTAINER=empire-jellyfin
EMPIRE_JELLYFIN_VERSION=latest
EMPIRE_JELLYFIN_HOST_PORT=8096

# --------------------------------------------------------------------
# Empire Core
# --------------------------------------------------------------------

EMPIRE_OBJECT_STORE_TOMBSTONE_DAYS=30
EMPIRE_STORAGE_ROOT_CONFIG=/Users/me/Documents/github/empire/object-store/config
EMPIRE_STORAGE_ROOT_GLOBAL=/Users/me/Documents/github/empire/object-store/global
EMPIRE_STORAGE_ROOT_JELLYFIN=/Users/me/Documents/github/empire/object-store/jellyfin

